          <div class="score-sub">respuestas</div>
        </div>
        <div class="result-msg" id="result-msg">¡Buen trabajo!</div>
        <div class="result-verse" id="result-verse"></div>
      </div>
      <div id="result-review"></div>
      <div style="height:1rem;"></div>
      <button class="btn btn-outline btn-sm" onclick="resetStudent()">← Volver</button>
