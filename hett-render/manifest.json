  <button id="float-lock" onclick="lockApp()" style="background:rgba(14,44,48,0.92);border:1px solid rgba(232,125,74,0.5);color:#F2A878;border-radius:18px;padding:7px 16px;font-size:0.72rem;font-family:'Cinzel',serif;letter-spacing:0.1em;cursor:pointer;">🔒 Bloquear</button>
</div>
</div>

