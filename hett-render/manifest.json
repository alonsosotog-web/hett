<!-- ═══════════════════════════════════════════════ MÉTRICAS -->
<div id="view-metrics" class="view">
  <div class="metric-row">
    <div class="metric-tile"><div class="mval" id="m-sessions">0</div><div class="mlbl">Sesiones</div></div>
    <div class="metric-tile"><div class="mval" id="m-participants">0</div><div class="mlbl">Participantes</div></div>
