    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px;">
      <div id="btn-profesor" onclick="selectProfile('profesor')" style="padding:13px 8px;border-radius:11px;border:1px solid rgba(232,125,74,0.45);background:rgba(232,125,74,0.13);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:5px;">
