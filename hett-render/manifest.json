</div>

<!-- HERO — solo visible en modo profesor/métricas -->
<div class="hero" id="main-hero">
  <img class="hero-logo" src="data:image/png;base64," alt="IUMP Recoleta - Hoy Es Tu Tiempo">
  <div class="hero-title">Estudio Bíblico</div>
  <div class="hero-year-wrap">
