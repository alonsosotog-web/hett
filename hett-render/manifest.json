</div>

</main>

<div class="church-footer" id="main-footer">
  ✝ IUMP Recoleta · Hoy Es Tu Tiempo · Ven a Jesús · Unión #439 · ¡Somos Familia!
</div>

<script>
// ── PWA Service Worker (auto-update) ─────────────────────────────────────────
if ('serviceWorker' in navigator) {
  // Unregister old SW to force fresh load always
  navigator.serviceWorker.getRegistrations().then(regs => {
    regs.forEach(r => r.unregister());
  });
}


// ── Collage fotos ─────────────────────────────────────────────────────────────
const CHURCH_PHOTOS = [
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
  "data:image/jpeg;base64,",
];
function initCollage() {
  const collage = document.getElementById('login-collage');
  if (!collage) return;
  collage.style.display = 'block';
}

function goHome() {
  // Go back to teacher view (main panel)
  const teacherBtn = document.querySelector('.tab-bar button:first-child');
  showView('teacher', teacherBtn || document.querySelector('.tab-bar button'));
}
function lockApp() {
  sessionStorage.removeItem('hett_auth');
  const tb = document.getElementById('top-bar-btns'); if(tb) tb.style.display = 'none';
  document.getElementById('login-overlay').classList.remove('hidden');
  document.getElementById('login-collage').style.display = 'block';
  initCollage();
  document.getElementById('login-pw').value = '';
  document.getElementById('login-error').textContent = '';
  setTimeout(() => document.getElementById('login-pw').focus(), 100);
}

function selectProfile(profile) {
  const btnP = document.getElementById('btn-profesor');
  const btnE = document.getElementById('btn-estudiante');
  const pwWrap = document.getElementById('login-pw-wrap');
  const nameWrap = document.getElementById('login-name-wrap');
  if (profile === 'profesor') {
    btnP.style.background = 'rgba(232,125,74,0.18)';
    btnP.style.borderColor = 'rgba(232,125,74,0.55)';
    btnE.style.background = 'rgba(27,79,82,0.5)';
    btnE.style.borderColor = 'rgba(232,125,74,0.22)';
    pwWrap.style.display = 'block';
    nameWrap.style.display = 'none';
  } else {
    btnE.style.background = 'rgba(232,125,74,0.18)';
    btnE.style.borderColor = 'rgba(232,125,74,0.55)';
    btnP.style.background = 'rgba(27,79,82,0.5)';
    btnP.style.borderColor = 'rgba(232,125,74,0.22)';
    pwWrap.style.display = 'none';
    nameWrap.style.display = 'flex';
  }
  window._loginProfile = profile;
}
function checkLogin() {
  const profile = window._loginProfile || 'profesor';
  const errEl = document.getElementById('login-error');

  if (profile === 'estudiante') {
    const nombreEl = document.getElementById('login-nombre');
    const apellidoEl = document.getElementById('login-apellido');
    const nombre = nombreEl ? nombreEl.value.trim() : '';
    const apellido = apellidoEl ? apellidoEl.value.trim() : '';
    if (!nombre) {
      if (errEl) errEl.textContent = '✕ Ingresa tu nombre';
      return;
    }
    sessionStorage.setItem('hett_auth', '1');
    sessionStorage.setItem('hett_student_name', (nombre + ' ' + apellido).trim());
    sessionStorage.setItem('hett_profile', 'student');
    document.getElementById('login-overlay').classList.add('hidden');
    document.getElementById('login-collage').style.display = 'none';
    const tbS = document.getElementById('top-bar-btns'); if(tbS) tbS.style.display = 'flex';
    // Show student view via tab click
    const studentBtn = document.querySelector('.tab-bar button:nth-child(2)');
    showView('student', studentBtn || document.querySelector('.tab-bar button'));
    return;
  }

  // Profesor
  const pwEl = document.getElementById('login-pw');
  const val = pwEl ? pwEl.value : '';
  if (val === PASS) {
    document.getElementById('login-overlay').classList.add('hidden');
    document.getElementById('login-collage').style.display = 'none';
    const topBar = document.getElementById('top-bar-btns');
    if (topBar) topBar.style.display = 'flex';
    sessionStorage.setItem('hett_auth', '1');
    sessionStorage.setItem('hett_profile', 'teacher');
    // Show teacher view
    const teacherBtn = document.querySelector('.tab-bar button:first-child');
    showView('teacher', teacherBtn || document.querySelector('.tab-bar button'));
  } else {
    if (errEl) errEl.textContent = '✕ Contraseña incorrecta';
    if (pwEl) { pwEl.value = ''; pwEl.focus(); }
  }
}
// Mostrar overlay si no está autenticado y NO es modo estudiante
window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const isStudent = params.get('sesion');
  if (isStudent) {
    // Student mode - hide everything admin
    const tb = document.getElementById('top-bar-btns'); if(tb) tb.style.display = 'none';
    document.getElementById('login-overlay').classList.add('hidden');
  } else if (sessionStorage.getItem('hett_auth') !== '1') {
    // Not authenticated - show login
    document.getElementById('login-overlay').classList.remove('hidden');
    const tb = document.getElementById('top-bar-btns'); if(tb) tb.style.display = 'none';
    initCollage();
    setTimeout(() => { const pw = document.getElementById('login-pw'); if(pw && pw.offsetParent !== null) pw.focus(); }, 100);
  } else {
    // Already authenticated
    document.getElementById('login-overlay').classList.add('hidden');
    const tb2 = document.getElementById('top-bar-btns'); if(tb2) tb2.style.display = 'flex';
  }
});

// ─── Storage via Netlify Blobs ───────────────────────────────────────────────
const API = '/api';
async function saveSession(code, quiz) {
  const r = await fetch(API, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'save_session',code,quiz})});
  return r.ok;
}
async function getSession(code) {
  try {
    const r = await fetch(API, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'get_session',code})});
    if(!r.ok) return null;
    const d = await r.json(); return d.quiz||null;
  } catch(e){return null;}
}
async function saveResult(result) {
  await fetch(API, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'save_result',result})});
}
async function getResults() {
  try {
    const r = await fetch(API, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'get_results'})});
    const d = await r.json(); return d.results||[];
  } catch(e){return[];}
}

// ─── State ────────────────────────────────────────────────────────────────────
let currentPdfText = null, currentQuiz = null;
let publishedQuiz = null, activeSessionCode = null;
let allResults = [], studentAnswers = {}, currentStudentName = '';
let isStudentMode = false; // true cuando viene del link de WhatsApp

// ─── Genera código de sesión único ───────────────────────────────────────────
function genCode() {
  const words = ['JUAN','LUCAS','MARCOS','PABLO','PEDRO','RUTH','ESTER','DAVID','MARIA','JESUS'];
  const w = words[Math.floor(Math.random() * words.length)];
  const n = String(Math.floor(Math.random() * 900) + 100);
  return w + '-' + n;
}

// ─── Init: detectar si viene por link ─────────────────────────────────────────
window.addEventListener('DOMContentLoaded', async () => {
  const params = new URLSearchParams(window.location.search);
  const sessionCode = params.get('sesion');

  if (sessionCode) {
    // MODO ESTUDIANTE: vino del link de WhatsApp
    isStudentMode = true;
    document.getElementById('main-hero').style.display = 'none';
    document.getElementById('main-tabs').style.display = 'none';
    document.getElementById('main-footer').style.display = 'none';
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById('view-student').classList.add('active');
    document.getElementById('student-waiting').style.display = 'none';
    document.getElementById('student-entry').style.display = 'block';
    await loadSessionForStudent(sessionCode);
  } else {
    // MODO NORMAL: app del profesor
    allResults = [];
    const stored = await getSession('__latest__');
    if (stored) { publishedQuiz = stored; activeSessionCode = stored.sessionCode || null; }
  }
});

async function loadSessionForStudent(code) {
  const quiz = await getSession(code);
  if (quiz) {
    publishedQuiz = quiz;
    document.getElementById('entry-topic-name').textContent = quiz.topic;
    document.getElementById('student-entry').querySelector('.entry-code-badge') && null;
  } else {
    document.getElementById('entry-topic-name').textContent = 'Sesión no encontrada';
    setStatus(document.getElementById('entry-status'), 'error', '✕ Código de sesión inválido o expirado.');
  }
}

// ─── Navegación ───────────────────────────────────────────────────────────────
function showView(name, btn) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab-bar button').forEach(b => b.classList.remove('active'));
  const view = document.getElementById('view-' + name);
  if (view) view.classList.add('active');
  if (btn) btn.classList.add('active');
  if (name === 'metrics') renderMetrics();
  if (name === 'student') checkForPublishedQuiz();
}

// ─── Profesor: subir archivo ──────────────────────────────────────────────────
// Carga PDF.js desde CDN una sola vez
function loadPdfJs() {
  return new Promise((resolve, reject) => {
    if (window.pdfjsLib) { resolve(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
    s.onload = () => { window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; resolve(); };
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

// Extrae todo el texto de un PDF como string
async function extractPdfText(file) {
  await loadPdfJs();
  const arrayBuffer = await file.arrayBuffer();
  const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  let fullText = '';
  for (let i = 1; i <= pdf.numPages; i++) {
    const page = await pdf.getPage(i);
    const content = await page.getTextContent();
    fullText += content.items.map(item => item.str).join(' ') + '\n';
  }
  return fullText.trim();
}

async function handleFile(input) {
  const file = input.files[0]; if (!file) return;
  const statusEl = document.getElementById('teacher-status');
  document.getElementById('file-name').textContent = '⏳ Leyendo PDF…';
  setStatus(statusEl, 'loading', '<span class="spinner"></span> Extrayendo texto del PDF…');
  try {
    currentPdfText = await extractPdfText(file);
    document.getElementById('file-name').textContent = '✓ ' + file.name + ' (' + currentPdfText.length + ' caracteres leídos)';
    document.getElementById('upload-zone').classList.add('has-file');
    statusEl.innerHTML = '';
    checkCanGenerate();
  } catch(e) {
    setStatus(statusEl, 'error', '✕ No se pudo leer el PDF: ' + e.message);
    document.getElementById('file-name').textContent = '';
  }
}

function checkCanGenerate() {
  document.getElementById('gen-btn').disabled =
    !(currentPdfText || document.getElementById('topic-input').value.trim());
}

// ─── Profesor: generar test ───────────────────────────────────────────────────
async function generateQuiz() {
  const topic = document.getElementById('topic-input').value.trim();
  const numQ = parseInt(document.getElementById('num-questions').value);
  const statusEl = document.getElementById('teacher-status');
  const btn = document.getElementById('gen-btn');
  btn.disabled = true;
  setStatus(statusEl, 'loading', '<span class="spinner"></span> Generando test bíblico …');
  try {
    let prompt;
    if (currentPdfText) {
      // PDF disponible: incluir texto extraído directamente en el prompt
      const excerpt = currentPdfText.slice(0, 6000); // máx 6000 chars para no exceder tokens
      prompt = `Eres un pastor y maestro bíblico de la Iglesia Unida Metodista Pentecostal "Hoy Es Tu Tiempo", Recoleta, Chile. Usas la Biblia Reina Valera 1960.\n\nEL SIGUIENTE ES EL CONTENIDO DEL MATERIAL DE CLASE:\n---\n${excerpt}\n---\n\n${topic ? `El tema es: "${topic}".` : ''}\nCrea ${numQ} preguntas de opción múltiple (4 opciones) basadas principalmente en el material anterior. Preguntas claras, nivel adulto, fieles a la Palabra.\n\nResponde ÚNICAMENTE con JSON válido sin backticks:\n{"topic":"Nombre del tema","questions":[{"q":"Pregunta","options":["A","B","C","D"],"answer":0}]}\n\n"answer"=índice 0-3 de la respuesta correcta.`;
    } else {
      prompt = `Eres un pastor y maestro bíblico de la Iglesia Unida Metodista Pentecostal "Hoy Es Tu Tiempo", Recoleta, Chile. Usas la Biblia Reina Valera 1960.\n${topic ? `El tema de hoy es: "${topic}".` : ''}\nCrea ${numQ} preguntas de opción múltiple (4 opciones) para evaluar a los hermanos. Preguntas claras, nivel adulto, fieles a la Palabra.\n\nResponde ÚNICAMENTE con JSON válido sin backticks:\n{"topic":"Nombre del tema","questions":[{"q":"Pregunta","options":["A","B","C","D"],"answer":0}]}\n\n"answer"=índice 0-3 de la respuesta correcta. Incluye referencias bíblicas (RVR 1960) cuando sea pertinente.`;
    }
    const messages = [{role:"user", content: prompt}];
    const res = await fetch("/api", {method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages})});
    const data = await res.json();
    if (!res.ok) throw new Error(data.error?.message || 'Error de API');
    let raw = data.content.map(c => c.text || '').join('');
    // Extraer solo el bloque JSON (entre { y }) ignorando texto extra del modelo
    const jsonMatch = raw.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error('El sistema no devolvió JSON válido. Intenta de nuevo.');
    raw = jsonMatch[0]
      .replace(/```json|```/g, '')
      .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F]/g, '') // control chars
      .replace(/\n/g, ' ')
      .trim();
    currentQuiz = JSON.parse(raw);
    setStatus(statusEl, 'success', '✓ Test generado. Revisa las preguntas antes de publicar.');
    renderPreview();
    document.getElementById('quiz-preview').style.display = 'block';
    document.getElementById('quiz-preview').scrollIntoView({behavior:'smooth',block:'start'});
  } catch(err) {
    setStatus(statusEl, 'error', '✕ Error: ' + err.message);
    btn.disabled = false;
  }
}

function renderPreview() {
  document.getElementById('preview-questions').innerHTML = currentQuiz.questions.map((q,i) => `
    <div class="question-block">
      <div class="q-num">Pregunta ${i+1}</div>
      <div class="q-text">${q.q}</div>
      <div class="options">${q.options.map((opt,j) => `<label class="${j===q.answer?'correct':''}" ><input type="radio" disabled ${j===q.answer?'checked':''} > ${opt}</label>`).join('')}</div>
    </div>`).join('');
}

// ─── Profesor: publicar y generar link ────────────────────────────────────────
async function publishQuiz() {
  const customName = document.getElementById('session-name-input').value.trim();
  const code = customName ? customName.toUpperCase().replace(/[^A-Z0-9ÁÉÍÓÚÑ ]/gi,'').replace(/ +/g,'-').slice(0,20) : genCode();
  activeSessionCode = code;
  const quizData = { ...currentQuiz, sessionCode: code, date: new Date().toLocaleDateString('es-CL') };
  publishedQuiz = quizData;

  // Guardar en storage compartido bajo la clave de sesión
  await saveSession(code, quizData);
  await saveSession('__latest__', quizData);

  setStatus(document.getElementById('publish-status'), 'success', '✝ Publicado — ¡comparte el link con los hermanos!');

  // Mostrar tarjeta de sesión
  document.getElementById('sc-code').textContent = code;
  document.getElementById('sc-topic').textContent = '📖 ' + quizData.topic;
  const link = getSessionLink(code);
  document.getElementById('sc-link-text').textContent = link;
  document.getElementById('session-card-wrap').style.display = 'block';
  document.getElementById('session-card-wrap').scrollIntoView({behavior:'smooth',block:'start'});
}

function getSessionLink(code) {
  const base = window.location.href.split('?')[0];
  return base + '?sesion=' + code;
}

function copyLink() {
  const link = getSessionLink(activeSessionCode);
  navigator.clipboard.writeText(link).then(() => {
    const btn = document.getElementById('btn-copy-link');
    btn.textContent = '✓ Copiado'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copiar'; btn.classList.remove('copied'); }, 2000);
  }).catch(() => {
    prompt('Copia este link:', link);
  });
}

function shareWhatsApp() {
  const link = getSessionLink(activeSessionCode);
  const topic = publishedQuiz?.topic || 'el test';
  const msg = `✝ *Estudio Bíblico 2026*\n_Hoy Es Tu Tiempo · IUMP Recoleta_\n\nHermanos, ya está listo el test de hoy: *${topic}*\n\nIngresa desde aquí 👇\n${link}\n\n¡Somos Familia!`;
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

// ─── Participante: chequear si hay sesión local (tab Participar) ──────────────
async function checkForPublishedQuiz() {
  const stored = await getSession('__latest__');
  if (stored) {
    publishedQuiz = stored;
    document.getElementById('student-waiting').style.display = 'none';
    document.getElementById('student-entry').style.display = 'block';
    document.getElementById('entry-topic-name').textContent = stored.topic;
  } else {
    document.getElementById('student-waiting').style.display = 'block';
    document.getElementById('student-entry').style.display = 'none';
    document.getElementById('student-quiz').style.display = 'none';
    document.getElementById('student-result').style.display = 'none';
  }
}

// ─── Participante: comenzar test ──────────────────────────────────────────────
function startQuiz() {
  const fn = document.getElementById('student-firstname').value.trim();
  const ln = document.getElementById('student-lastname').value.trim();
  if (!fn || !ln) {
    setStatus(document.getElementById('entry-status'), 'error', '✕ Por favor ingresa tu nombre y apellido.');
    return;
  }
  currentStudentName = fn + ' ' + ln;
  studentAnswers = {};
  document.getElementById('student-entry').style.display = 'none';
  document.getElementById('student-quiz').style.display = 'block';
  document.getElementById('quiz-title-student').textContent = publishedQuiz.topic;
  document.getElementById('student-questions').innerHTML = publishedQuiz.questions.map((q,i) => `
    <div class="question-block">
      <div class="q-num">Pregunta ${i+1} de ${publishedQuiz.questions.length}</div>
      <div class="q-text">${q.q}</div>
      <div class="options">${q.options.map((opt,j) => `<label><input type="radio" name="q${i}" value="${j}" onchange="studentAnswers[${i}]=${j}"> ${opt}</label>`).join('')}</div>
    </div>`).join('');
  window.scrollTo(0,0);
}

// ─── Participante: enviar respuestas ──────────────────────────────────────────
async function submitQuiz() {
  const ua = publishedQuiz.questions.findIndex((_,i) => studentAnswers[i] === undefined);
  if (ua >= 0 && !confirm(`La pregunta ${ua+1} está sin responder. ¿Enviar de todos modos?`)) return;
  let correct = 0;
  publishedQuiz.questions.forEach((q,i) => { if (studentAnswers[i] === q.answer) correct++; });
  const total = publishedQuiz.questions.length, pct = Math.round((correct/total)*100);

  const result = {
    name: currentStudentName, topic: publishedQuiz.topic,
    sessionCode: publishedQuiz.sessionCode || '—',
    date: publishedQuiz.date || new Date().toLocaleDateString('es-CL'),
    correct, total, pct, answers: {...studentAnswers}
  };

  // Guardar resultado en storage compartido (para métricas del profesor)
  await saveResult(result);

  const verse = await getVerse(pct);
  document.getElementById('student-quiz').style.display = 'none';
  document.getElementById('student-result').style.display = 'block';
  document.getElementById('result-score').textContent = `${correct}/${total}`;
  const ring = document.getElementById('result-ring');
  ring.className = 'result-ring ' + (pct>=80?'great':pct>=60?'good':'keep');
  document.getElementById('result-msg').textContent = pct>=80?'¡Excelente hermano/a! 🎉':pct>=60?'¡Buen esfuerzo! Sigue adelante':'Sigue buscando la Palabra 💪';
  document.getElementById('result-verse').textContent = verse;
  document.getElementById('result-review').innerHTML = '<div class="wave-div" style="margin:0.5rem 0 1rem;">· · Revisión · ·</div>' +
    publishedQuiz.questions.map((q,i) => {
      const chosen = studentAnswers[i];
      return `<div class="question-block"><div class="q-num">Pregunta ${i+1}</div><div class="q-text">${q.q}</div><div class="options">${q.options.map((opt,j) => { let c=''; if(j===q.answer) c=chosen===j?'correct':'show-correct'; else if(j===chosen) c='wrong'; return `<label class="${c}"><input type="radio" disabled ${j===chosen?'checked':''} > ${opt}</label>`; }).join('')}</div></div>`;
    }).join('');
  window.scrollTo(0,0);
}

async function getVerse(pct) {
  try {
    const p = pct>=80 ? 'Dame un versículo bíblico corto de celebración (RVR 1960). Solo versículo y referencia.' : pct>=60 ? 'Dame un versículo bíblico corto de aliento (RVR 1960). Solo versículo y referencia.' : 'Dame un versículo bíblico corto de motivación (RVR 1960). Solo versículo y referencia.';
    const res = await fetch("/api",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages:[{role:"user",content:p}]})});
    const d = await res.json(); return d.content?.[0]?.text || '';
  } catch { return ''; }
}

function resetStudent() {
  document.getElementById('student-result').style.display = 'none';
  document.getElementById('student-firstname').value = '';
  document.getElementById('student-lastname').value = '';
  document.getElementById('entry-status').innerHTML = '';
  if (isStudentMode) {
    document.getElementById('student-entry').style.display = 'block';
  } else {
    checkForPublishedQuiz();
  }
}

// ─── Métricas ─────────────────────────────────────────────────────────────────
async function renderMetrics() {
  const data = await getResults();
  allResults = data;
  if (!data.length) return;
  const sessions = [...new Set(data.map(r => r.sessionCode || r.topic+'|'+r.date))].length;
  const avg = Math.round(data.reduce((s,r) => s+r.pct,0) / data.length);
  const best = Math.max(...data.map(r => r.pct));
  document.getElementById('m-sessions').textContent = sessions;
  document.getElementById('m-participants').textContent = data.length;
  document.getElementById('m-avg').textContent = avg+'%';
  document.getElementById('m-best').textContent = best+'%';
  const topicMap = {};
  data.forEach(r => { if(!topicMap[r.topic]) topicMap[r.topic]={correct:0,total:0,count:0}; topicMap[r.topic].correct+=r.correct; topicMap[r.topic].total+=r.total; topicMap[r.topic].count++; });
  const topics = Object.entries(topicMap).map(([t,d]) => ({t,pct:Math.round((d.correct/d.total)*100),count:d.count})).sort((a,b) => a.pct-b.pct);
  document.getElementById('topics-chart').innerHTML = topics.map(t => { const c=t.pct>=80?'great':t.pct>=60?'good':'keep'; return`<div class="bar-item"><div class="bar-head"><span class="bar-topic">${t.t.length>32?t.t.slice(0,30)+'…':t.t}</span><span class="bar-pct-label">${t.pct}%</span></div><div class="bar-track"><div class="bar-fill ${c}" style="width:${t.pct}%"></div></div><div class="bar-count">${t.count} participante${t.count!==1?'s':''}</div></div>`; }).join('');
  document.getElementById('participants-table').innerHTML = `<table class="p-table"><thead><tr><th>Nombre</th><th>Sesión</th><th>Fecha</th><th>Resultado</th></tr></thead><tbody>${[...data].reverse().map(r => { const c=r.pct>=80?'badge-great':r.pct>=60?'badge-good':'badge-keep'; return`<tr><td><strong>${r.name}</strong></td><td><span class="badge-session">${r.sessionCode||'—'}</span></td><td style="color:var(--gray-mid);font-size:0.78rem">${r.date}</td><td><span class="badge ${c}">${r.correct}/${r.total} · ${r.pct}%</span></td></tr>`; }).join('')}</tbody></table>`;
}

function exportCSV() {
  if (!allResults.length) { alert('No hay datos para exportar.'); return; }
  const csv = 'Nombre,Sesión,Tema,Fecha,Correctas,Total,Porcentaje\n' + allResults.map(r => `${r.name},${r.sessionCode||'—'},${r.topic},${r.date},${r.correct},${r.total},${r.pct}%`).join('\n');
  const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'})); a.download = 'hett_estudio_biblico_2026.csv'; a.click();
}

async function clearData() {
  if (!confirm('¿Eliminar todos los datos de todas las sesiones?')) return;
  await fetch(API, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'clear_data'})});
  allResults = [];
  ['m-sessions','m-participants','m-avg','m-best'].forEach(id => document.getElementById(id).textContent = '—');
  document.getElementById('topics-chart').innerHTML = '<div class="empty-state"><span>📖</span>Sin datos aún.</div>';
  document.getElementById('participants-table').innerHTML = '<div class="empty-state"><span>🫂</span>Sin participantes aún.</div>';
}

function setStatus(el, type, html) { el.innerHTML = `<div class="status ${type}">${html}</div>`; }

// Polling: actualizar métricas automáticamente cada 10s si está activa
setInterval(async () => {
  if (document.getElementById('view-metrics').classList.contains('active')) renderMetrics();
}, 10000);
</script>
