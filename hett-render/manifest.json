<main>

<!-- ═══════════════════════════════════════════════ PROFESOR -->
<div id="view-teacher" class="view active">
  <div class="card">
    <div class="section-title">📋 Preparar el test del día</div>

    <label class="field-label">Tema de la clase</label>
    <input type="text" id="topic-input" placeholder="Ej: Las Bienaventuranzas, Los Salmos…" oninput="checkCanGenerate()">

    <label class="field-label">Material en PDF (opcional)</label>
    <div class="upload-zone" id="upload-zone">
      <input type="file" id="pdf-input" accept=".pdf" onchange="handleFile(this)">
      <span class="uz-icon">📄</span>
      <p>Toca para seleccionar tu PDF</p>
      <div class="uz-file" id="file-name"></div>
    </div>

    <label class="field-label">Nombre de la sesión (opcional)</label>
    <input type="text" id="session-name-input" placeholder="Ej: Clase 3, Domingo 9 Mar, Grupo Jóvenes…">

    <label class="field-label">Número de preguntas</label>
    <select id="num-questions">
      <option value="5">5 preguntas</option>
      <option value="8" selected>8 preguntas</option>
      <option value="10">10 preguntas</option>
    </select>

    <button class="btn btn-primary" id="gen-btn" onclick="generateQuiz()" disabled>✦ Generar Test</button>
    <div id="teacher-status"></div>
  </div>

  <div id="quiz-preview" style="display:none;">
    <div class="wave-div">· · ✝ · ·</div>
    <div class="card">
      <div class="section-title">👁 Previsualizar Test</div>
      <div id="preview-questions"></div>
      <div style="height:0.5rem;"></div>
      <button class="btn btn-warm" onclick="publishQuiz()">✝ Publicar para los hermanos</button>
      <div id="publish-status"></div>
    </div>
  </div>

  <!-- TARJETA DE SESIÓN — aparece tras publicar -->
  <div id="session-card-wrap" style="display:none;">
    <div class="session-card">
      <div class="sc-label">Sesión activa</div>
      <div class="session-code-row">
        <div class="session-code" id="sc-code">—</div>
      </div>
      <div class="session-topic" id="sc-topic"></div>

      <div class="sc-label" style="margin-bottom:0.4rem;">Link para compartir</div>
      <div class="link-row">
        <span class="link-text" id="sc-link-text"></span>
        <button class="btn-copy" id="btn-copy-link" onclick="copyLink()">Copiar</button>
      </div>

      <button class="btn btn-wa" onclick="shareWhatsApp()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.847L.057 23.5l5.797-1.519A11.932 11.932 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.003-1.369l-.359-.214-3.44.902.918-3.352-.234-.373A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
        Enviar por WhatsApp
      </button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════ PARTICIPANTE -->
<div id="view-student" class="view">

  <!-- Pantalla de entrada — se usa cuando viene por el link -->
  <div id="student-entry" style="display:none;">
    <div class="entry-screen">
      <img class="entry-logo" src="data:image/png;base64," alt="HETT">
      <div class="entry-title">Estudio Bíblico</div>
      <div class="entry-year-wrap">
        <div class="entry-year-line"></div>
        <div class="entry-year">2026</div>
        <div class="entry-year-line"></div>
      </div>

      <div class="card">
