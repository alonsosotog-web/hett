<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta http-equiv="cache-control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="pragma" content="no-cache">
<meta http-equiv="expires" content="0">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#1A1008">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="HETT">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/icons/favicon.png">
<link rel="apple-touch-icon" href="/icons/icon-192.png">
<title>Estudio Bíblico 2026 · Hoy Es Tu Tiempo</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito:wght@400;600;700;800;900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --teal-d:  #1B4F52;
  --teal:    #2A7C82;
  --teal2:   #3D9EA6;
  --sage:    #8FA898;
  --sand:    #C4A882;
  --salmon:  #E87D4A;
  --peach:   #F2A878;
  --sky:     #E8C4A0;
  --cream:   #FDF0E0;
  --ink:     #0E2C30;
  --muted:   rgba(200,230,228,0.65);
  --wa:      #25D366;
  --success: #27AE60;
  --danger:  #C0392B;
  /* aliases para compatibilidad */
  --gold:       #E87D4A;
  --gold-light: #F2A878;
  --gold-pale:  #FDF0E0;
  --gold-glow:  rgba(232,125,74,0.35);
  --deep:       #0E2C30;
  --black:      #0E2C30;
  --text:       #FDF0E0;
  --text-soft:  rgba(200,230,228,0.7);
  --gray-mid:   rgba(200,230,228,0.5);
  --warm:       #E87D4A;
  --warm-light: #F2A878;
  --shadow:     0 4px 24px rgba(0,0,0,0.3);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
/* ── Login overlay ─────────────────────────────────────────────────────────── */
#login-overlay {
  position: fixed; inset: 0; z-index: 9999;
  background: transparent;
  display: flex; align-items: center; justify-content: center;
}
#login-overlay.hidden { display: none; }
\.login-box {
  position: relative; z-index: 10000;
  background: rgba(12,38,42,0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(232,125,74,0.4);
  border-radius: 20px;
  padding: 36px 32px;
  width: min(380px, 92vw);
  text-align: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(232,168,120,0.2);
}
.login-logo {
  width: 90px; margin: 0 auto 8px;
  filter: drop-shadow(0 0 12px rgba(201,150,42,0.6));
  animation: loginLogoGlow 3s ease-in-out infinite;
}
@keyframes loginLogoGlow {
  0%,100% { filter: drop-shadow(0 0 10px rgba(232,125,74,0.55)) drop-shadow(0 0 28px rgba(232,125,74,0.25)); }
  50% { filter: drop-shadow(0 0 22px rgba(232,125,74,0.9)) drop-shadow(0 0 50px rgba(242,168,120,0.4)); }
}
.login-title {
  font-family: 'Cinzel', serif; font-size: 1.55rem;
  color: #F2A878; letter-spacing: 0.18em;
  text-shadow: 0 1px 3px rgba(201,150,42,0.2);
}
.login-sub { font-size: 1.15rem; color: #3D9EA6; margin-top: -12px; font-family: 'EB Garamond', serif; font-style: italic; letter-spacing: 0.28em; }
.login-divider {
  display: flex; align-items: center; gap: 10px; margin: -4px 0;
}
.login-divider::before, .login-divider::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.login-divider span { color: var(--gold); font-size: 0.7rem; letter-spacing: 0.3em; font-family: 'Cinzel', serif; }
.login-input {
  width: 100%; padding: 13px 16px;
  border: 1px solid rgba(232,125,74,0.4);
  border-radius: 6px; font-size: 1rem; font-family: 'Nunito', sans-serif;
  background: rgba(255,255,255,0.07); color: #FDF0E0; text-align: center;
  letter-spacing: 0.2em;
  box-shadow: inset 0 2px 8px rgba(201,150,42,0.08), 0 0 0 0 transparent;
  transition: all 0.3s;
}
.login-input:focus {
  outline: none;
  border-color: var(--gold);
  box-shadow: inset 0 2px 8px rgba(201,150,42,0.1), 0 0 16px rgba(201,150,42,0.2);
}
.login-error { color: var(--danger); font-size: 0.82rem; min-height: 18px; }
.login-btn {
  background: linear-gradient(135deg, #8B6914 0%, var(--gold) 40%, #E8C060 60%, #C9962A 100%);
  color: var(--deep);
  border: none; border-radius: 6px; padding: 14px;
  font-family: 'Cinzel', serif; font-size: 0.85rem;
  font-weight: 700; letter-spacing: 0.15em; cursor: pointer;
  text-transform: uppercase;
  box-shadow: 0 4px 20px rgba(201,150,42,0.4), inset 0 1px 0 rgba(255,255,255,0.3);
  transition: all 0.3s;
}
.login-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 28px rgba(201,150,42,0.55), inset 0 1px 0 rgba(255,255,255,0.3);
}
/* ── Collage fondo login ────────────────────────────────────────────────────── */
#login-collage {
  position: fixed; inset: 0; z-index: 9998;
  background: url('data:image/png;base64,') center/cover no-repeat;
}
#login-collage::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(10,30,32,0.35) 0%, rgba(10,30,32,0.55) 100%);
}

#login-overlay {
  position: fixed; inset: 0; z-index: 9999;
  background: transparent;
  display: flex; align-items: center; justify-content: center;
}
\.login-box {
  position: relative; z-index: 10000;
  background: rgba(12,38,42,0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(232,125,74,0.4);
  border-radius: 20px;
  padding: 36px 32px;
  width: min(380px, 92vw);
  text-align: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(232,168,120,0.2);
}


body { font-family: 'Nunito', sans-serif; background: var(--teal-d); color: var(--cream); min-height: 100vh; }

/* ── HERO SAGRADO ─────────────────────────────────────────────────────────── */
.hero {
  background: var(--teal-d);
  padding: 2.8rem 1.5rem 3.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
  border-bottom: 2px solid var(--salmon);
}
/* Fondo con textura de luz divina */
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% -10%, rgba(201,150,42,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 50% 110%, rgba(201,150,42,0.12) 0%, transparent 70%),
    repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(201,150,42,0.015) 40px, rgba(201,150,42,0.015) 41px),
    repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(201,150,42,0.015) 40px, rgba(201,150,42,0.015) 41px);
  pointer-events: none;
}
/* Ola inferior crema */
.hero::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0; height: 48px;
  background: var(--off-white);
  clip-path: ellipse(55% 100% at 50% 100%);
}
.hero-logo {
  max-width: 300px; width: 85%; margin: 0 auto 1.2rem; display: block;
  border-radius: 8px;
  mix-blend-mode: luminosity;
  filter: 
    drop-shadow(0 0 8px rgba(201,150,42,0.9))
    drop-shadow(0 0 20px rgba(201,150,42,0.6))
    drop-shadow(0 0 45px rgba(201,150,42,0.35))
    drop-shadow(0 0 80px rgba(201,150,42,0.15))
    contrast(1.05);
  position: relative; z-index: 1;
  animation: heroFloat 6s ease-in-out infinite;
}
@keyframes heroFloat {
  0%,100% { transform: translateY(0px); }
  50% { transform: translateY(-5px); }
}
.hero-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.15rem, 3.5vw, 1.7rem);
  color: var(--gold-light);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 700;
  line-height: 1.2;
  position: relative; z-index: 1;
  text-shadow: 0 0 30px rgba(201,150,42,0.4);
}
.hero-year-wrap {
  display: flex; align-items: center; justify-content: center;
  margin: 0.8rem auto 0; max-width: 300px;
  position: relative; z-index: 1;
}
.hero-year-line {
  flex: 1; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.hero-year {
  font-family: 'Cinzel', serif; font-size: 0.72rem; font-weight: 400;
  color: var(--gold); letter-spacing: 0.5em; padding: 0 1rem;
  white-space: nowrap; text-transform: uppercase;
}
.hero-lock-btn { display: none; }

/* Botón flotante fijo arriba a la derecha */
#float-lock {
  position: fixed; top: 12px; right: 14px; z-index: 8000;
  background: rgba(13,8,4,0.88);
  border: 1px solid rgba(201,150,42,0.6);
  color: #E8C060;
  border-radius: 20px; padding: 7px 16px;
  font-size: 0.73rem; font-family: 'Cinzel', serif;
  letter-spacing: 0.1em; cursor: pointer;
  backdrop-filter: blur(8px);
  box-shadow: 0 2px 16px rgba(0,0,0,0.45), 0 0 0 1px rgba(201,150,42,0.15);
  transition: all 0.2s;
  display: none;
}
#float-lock:hover {
  background: rgba(201,150,42,0.25);
  border-color: #E8C060;
  box-shadow: 0 4px 20px rgba(201,150,42,0.3);
}
.hero-address {
  color: rgba(201,150,42,0.55); font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.9rem;
  font-family: 'Cinzel', serif;
  position: relative; z-index: 1;
}

/* TABS */
.tab-bar { display: flex; background: var(--cream2); border-bottom: 2px solid var(--black); margin: -1rem 0 0; position: relative; z-index: 10; }
.tab-bar button { flex: 1; border: none; background: none; font-family: 'Nunito', sans-serif; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-soft); padding: 0.9rem 0.5rem 0.8rem; cursor: pointer; transition: all 0.2s; border-bottom: 3px solid transparent; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; margin-bottom: -2px; }
.tab-bar button .tab-icon { font-size: 1.3rem; }
.tab-bar button:hover { color: var(--black); background: var(--cream); }
.tab-bar button.active { color: var(--black); border-bottom-color: var(--black); background: var(--off-white); }

/* MAIN */
main { padding: 1.8rem 1rem 3rem; max-width: 700px; margin: 0 auto; }
.view { display: none; }
.view.active { display: block; animation: fadeUp 0.35s ease; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

/* SECTION TITLE */
.section-title { font-family: 'Libre Baskerville', serif; font-size: 1rem; color: var(--salmon); margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.5rem; letter-spacing: 0.05em; text-transform: uppercase; }
.section-title::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg,var(--gray) 0%,transparent 100%); margin-left: 0.5rem; }

/* CARDS */
.card { background: linear-gradient(160deg, rgba(24,72,78,0.94), rgba(18,56,60,0.97)); border-radius: 4px; padding: 1.5rem; margin-bottom: 1.2rem; box-shadow: var(--shadow); border: 1px solid var(--gray); }
.card-cream { background: var(--cream); border-color: var(--cream2); }

/* INPUTS */
label.field-label { display: block; font-size: 0.75rem; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; color: var(--salmon); margin-bottom: 0.4rem; }
input[type="text"], select { width: 100%; background: var(--off-white); border: 2px solid var(--gray); border-radius: 4px; color: var(--text); font-family: 'Nunito', sans-serif; font-size: 0.95rem; font-weight: 600; padding: 0.7rem 1rem; outline: none; transition: border-color 0.2s; margin-bottom: 1rem; }
input[type="text"]:focus, select:focus { border-color: var(--black); background: #fff; }
input[type="text"]::placeholder { color: var(--gray-mid); font-weight: 400; }

/* FILE UPLOAD */
.upload-zone { border: 2px dashed var(--gray-mid); border-radius: 4px; padding: 2rem 1.5rem; text-align: center; cursor: pointer; transition: all 0.2s; margin-bottom: 1rem; position: relative; background: var(--off-white); }
.upload-zone:hover { border-color: var(--black); background: var(--cream); }
.upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.upload-zone .uz-icon { font-size: 2rem; margin-bottom: 0.5rem; display: block; }
.upload-zone p { color: var(--text-soft); font-size: 0.88rem; font-weight: 600; }
.upload-zone .uz-file { color: var(--black); font-weight: 800; margin-top: 0.4rem; font-size: 0.88rem; }
.upload-zone.has-file { border-color: var(--success); background: #F0FFF6; border-style: solid; }

/* BUTTONS */
.btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; padding: 0.85rem 1.8rem; border-radius: 4px; font-family: 'Nunito', sans-serif; font-size: 0.88rem; font-weight: 900; cursor: pointer; border: none; transition: all 0.18s; letter-spacing: 0.05em; text-transform: uppercase; }
.btn-primary { background: linear-gradient(135deg, #A84E20, var(--salmon), var(--peach), var(--salmon), #B85A28); color: var(--ink); width: 100%; }
.btn-primary:hover { background: #2C1F0A; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.25); }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }
.btn-warm { background: var(--warm); color: #fff; width: 100%; box-shadow: 0 3px 12px rgba(232,131,42,0.3); }
.btn-warm:hover { background: #D4721A; transform: translateY(-1px); }
.btn-wa { background: var(--wa); color: #fff; width: 100%; box-shadow: 0 3px 12px rgba(37,211,102,0.3); font-size: 0.95rem; padding: 1rem; }
.btn-wa:hover { background: #1DA851; transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--black); border: 2px solid var(--black); padding: 0.65rem 1.5rem; width: auto; }
.btn-outline:hover { background: var(--cream); }
.btn-sm { padding: 0.55rem 1.2rem; font-size: 0.78rem; width: auto; }
.btn-copy { background: var(--cream2); color: var(--black); border: 1.5px solid var(--gray); padding: 0.6rem 1rem; font-size: 0.78rem; font-weight: 800; border-radius: 4px; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.btn-copy:hover { background: var(--cream); border-color: var(--black); }
.btn-copy.copied { background: #EBF8F1; border-color: rgba(39,174,96,0.5); color: #1E7A46; }

/* STATUS */
.status { border-radius: 4px; padding: 0.9rem 1rem; font-size: 0.88rem; font-weight: 700; margin-top: 1rem; display: flex; align-items: center; gap: 0.6rem; }
.status.loading { background: var(--cream); color: var(--black); border: 1.5px solid var(--gray-mid); }
.status.error { background: #FFF0EE; color: var(--danger); border: 1.5px solid rgba(192,57,43,0.3); }
.status.success { background: #F0FFF6; color: #1E7A46; border: 1.5px solid rgba(39,174,96,0.4); }
.spinner { display: inline-block; width: 16px; height: 16px; border: 2.5px solid rgba(26,16,8,0.2); border-top-color: var(--black); border-radius: 50%; animation: spin 0.8s linear infinite; flex-shrink: 0; }
@keyframes spin { to { transform: rotate(360deg); } }

/* SESSION CODE CARD */
.session-card { background: var(--black); color: var(--cream); border-radius: 4px; padding: 1.5rem; margin-bottom: 1.2rem; }
.session-card .sc-label { font-size: 0.65rem; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.55; margin-bottom: 0.5rem; }
.session-code-row { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
.session-code { font-family: 'Libre Baskerville', serif; font-size: 2rem; font-weight: 700; letter-spacing: 0.25em; color: var(--cream); flex: 1; }
.session-topic { font-family: 'Libre Baskerville', serif; font-style: italic; font-size: 0.9rem; opacity: 0.7; margin-bottom: 1.2rem; }
.link-row { display: flex; align-items: center; gap: 0.6rem; background: rgba(240,234,216,0.08); border: 1px solid rgba(240,234,216,0.2); border-radius: 4px; padding: 0.6rem 0.8rem; margin-bottom: 1rem; }
.link-text { font-size: 0.72rem; color: rgba(240,234,216,0.6); font-family: monospace; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* QUESTIONS */
.question-block { background: var(--off-white); border: 1.5px solid var(--gray); border-radius: 4px; padding: 1.2rem 1.2rem 0.8rem; margin-bottom: 1rem; }
.q-num { display: inline-block; background: var(--black); color: var(--cream); font-size: 0.68rem; font-weight: 900; padding: 0.2rem 0.6rem; border-radius: 3px; margin-bottom: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; }
.q-text { font-family: 'Libre Baskerville', serif; font-size: 0.97rem; color: var(--text); line-height: 1.65; margin-bottom: 0.9rem; }
.options label { display: flex; align-items: flex-start; gap: 0.65rem; padding: 0.6rem 0.8rem; border-radius: 4px; cursor: pointer; margin-bottom: 0.35rem; border: 1.5px solid transparent; transition: all 0.15s; font-size: 0.9rem; font-weight: 600; color: var(--salmon); }
.options label:hover { background: var(--cream); border-color: var(--gray); color: var(--text); }
.options input[type="radio"] { width: auto; accent-color: var(--black); margin: 0; flex-shrink: 0; margin-top: 2px; }
.options label.correct { background: #EBF8F1; border-color: rgba(39,174,96,0.5); color: #1E7A46; }
.options label.wrong { background: #FFF0EE; border-color: rgba(192,57,43,0.4); color: var(--danger); }
.options label.show-correct { background: #EBF8F1; border-color: rgba(39,174,96,0.35); color: #1E7A46; }

/* ── STUDENT ENTRY SAGRADA ─────────────────────────────────────────────────── */
.entry-screen {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: center;
  padding: 2rem 0;
  background: var(--deep);
  position: relative; overflow: hidden;
}
/* Luz divina desde arriba */
.entry-screen::before {
  content: '';
  position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  width: 120%; height: 55%;
  background: radial-gradient(ellipse at 50% 0%, rgba(201,150,42,0.22) 0%, transparent 70%);
  pointer-events: none;
}
/* Cruz decorativa de luz */
.entry-screen::after {
  content: '';
  position: absolute; top: 8%; left: 50%; transform: translateX(-50%);
  width: 1px; height: 120px;
  background: linear-gradient(180deg, rgba(201,150,42,0.6), transparent);
  pointer-events: none;
}
.entry-screen .entry-h-line {
  position: absolute; top: calc(8% + 48px); left: 50%; transform: translate(-50%, 0);
  width: 80px; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(201,150,42,0.5), transparent);
}
.entry-logo {
  max-width: 200px; width: 75%; margin: 0 auto 1.2rem; display: block;
  border-radius: 8px;
  mix-blend-mode: luminosity;
  filter:
    drop-shadow(0 0 8px rgba(201,150,42,0.9))
    drop-shadow(0 0 20px rgba(201,150,42,0.6))
    drop-shadow(0 0 45px rgba(201,150,42,0.35))
    contrast(1.05);
  position: relative; z-index: 1;
  animation: heroFloat 6s ease-in-out infinite;
}
.entry-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.1rem, 3.5vw, 1.5rem);
  color: var(--gold-light);
  text-align: center; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  margin-bottom: 0.4rem;
  text-shadow: 0 0 20px rgba(201,150,42,0.4);
  position: relative; z-index: 1;
}
.entry-year-wrap {
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.8rem; max-width: 200px;
  position: relative; z-index: 1;
}
.entry-year-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
.entry-year {
  font-family: 'Cinzel', serif; font-size: 0.68rem;
  color: var(--gold); letter-spacing: 0.45em; padding: 0 0.8rem;
}
/* Card del formulario sobre fondo oscuro */
.entry-screen .card {
  background: rgba(250,246,238,0.96);
  border: 1px solid rgba(201,150,42,0.3);
  box-shadow: 0 4px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(201,150,42,0.1);
  position: relative; z-index: 1;
}
.entry-topic-pill {
  background: rgba(201,150,42,0.08);
  border: 1px solid rgba(201,150,42,0.35);
  border-radius: 4px; padding: 0.9rem 1.2rem; margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 0.8rem;
}
.entry-topic-pill .etp-icon { font-size: 1.4rem; flex-shrink: 0; }
.entry-topic-pill .etp-label {
  font-family: 'Cinzel', serif; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.18em; color: var(--salmon);
}
.entry-topic-pill .etp-name {
  font-family: 'EB Garamond', serif; font-size: 1rem;
  color: var(--black); font-weight: 600; font-style: italic;
}
.entry-code-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: linear-gradient(135deg, #8B6914, var(--gold));
  color: var(--deep); border-radius: 3px; padding: 0.3rem 0.9rem;
  font-family: 'Cinzel', serif; font-size: 0.68rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 1.5rem;
  box-shadow: 0 2px 10px rgba(201,150,42,0.35);
}
.name-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
.name-row .field-wrap { display: flex; flex-direction: column; }
.name-row input { margin-bottom: 0; }

/* RESULT */
.result-hero { text-align: center; padding: 2rem 1rem 1.5rem; }
.result-ring { width: 110px; height: 110px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-direction: column; margin: 0 auto 1rem; }
.result-ring.great { background: var(--black); border: 4px solid #52D68A; }
.result-ring.good { background: var(--black); border: 4px solid var(--warm-light); }
.result-ring.keep { background: var(--black); border: 4px solid var(--cream2); }
.result-ring .score-num { font-size: 2rem; font-weight: 900; color: var(--cream); line-height: 1; }
.result-ring .score-sub { font-size: 0.6rem; color: rgba(240,234,216,0.7); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
.result-msg { font-family: 'Libre Baskerville', serif; font-size: 1.05rem; color: var(--black); font-weight: 700; margin-bottom: 0.3rem; }
.result-verse { background: var(--cream); border-left: 3px solid var(--black); border-radius: 0 4px 4px 0; padding: 1rem 1.2rem; font-family: 'Libre Baskerville', serif; font-style: italic; font-size: 0.92rem; color: var(--black); line-height: 1.7; margin: 1rem 0; text-align: left; }

/* METRICS */
.metric-row { display: grid; grid-template-columns: repeat(2,1fr); gap: 0.8rem; margin-bottom: 1.2rem; }
.metric-tile { background: #fff; border: 1.5px solid var(--gray); border-radius: 4px; padding: 1.1rem; text-align: center; }
.metric-tile .mval { font-size: 1.9rem; font-weight: 900; color: var(--black); line-height: 1; }
.metric-tile .mlbl { font-size: 0.7rem; font-weight: 700; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.3rem; }

/* BAR */
.bar-item { margin-bottom: 0.9rem; }
.bar-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.3rem; }
.bar-topic { font-size: 0.85rem; font-weight: 700; color: var(--text); }
.bar-pct-label { font-size: 0.8rem; font-weight: 900; color: var(--salmon); }
.bar-track { background: var(--gray); border-radius: 2px; height: 10px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
.bar-fill.great { background: linear-gradient(90deg,#27AE60,#52D68A); }
.bar-fill.good { background: linear-gradient(90deg,var(--warm),var(--warm-light)); }
.bar-fill.keep { background: linear-gradient(90deg,#8B9BB4,#A8B8CA); }
.bar-count { font-size: 0.72rem; color: var(--gray-mid); font-weight: 600; margin-top: 0.2rem; }

/* TABLE */
.p-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.p-table th { text-align: left; padding: 0.6rem 0.8rem; color: var(--text-soft); font-size: 0.7rem; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; border-bottom: 2px solid var(--black); }
.p-table td { padding: 0.65rem 0.8rem; border-bottom: 1px solid var(--gray); color: var(--text); }
.p-table tr:last-child td { border-bottom: none; }
.p-table tr:hover td { background: var(--cream); }

/* BADGE */
.badge { display: inline-block; padding: 0.2rem 0.65rem; border-radius: 2px; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.05em; }
.badge-great { background: #EBF8F1; color: #1E7A46; border: 1px solid rgba(39,174,96,0.3); }
.badge-good { background: #FFF4EC; color: #C4601A; border: 1px solid rgba(232,131,42,0.3); }
.badge-keep { background: var(--cream); color: var(--text-soft); border: 1px solid var(--gray); }
.badge-session { background: var(--cream); color: var(--text-soft); border: 1px solid var(--gray); font-size: 0.68rem; padding: 0.15rem 0.5rem; font-family: monospace; letter-spacing: 0.1em; }

/* WAITING */
.waiting-screen { text-align: center; padding: 3rem 1.5rem; }
.waiting-screen .w-icon { font-size: 3.5rem; margin-bottom: 1rem; display: block; }
.waiting-screen h2 { font-family: 'Libre Baskerville', serif; color: var(--black); margin-bottom: 0.5rem; font-size: 1.2rem; }
.waiting-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--black); animation: pulse 1.4s ease-in-out infinite; margin: 0 3px; opacity: 0.4; }
.waiting-dot:nth-child(2) { animation-delay: 0.2s; }
.waiting-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse { 0%,100% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.4); opacity: 1; } }

/* EMPTY */
.empty-state { text-align: center; padding: 2rem 1rem; color: var(--gray-mid); font-weight: 600; font-size: 0.9rem; }
.empty-state span { display: block; font-size: 2.5rem; margin-bottom: 0.8rem; }

/* TOPIC PILL */
.topic-pill { display: flex; align-items: center; gap: 0.7rem; background: var(--black); color: var(--cream); border-radius: 4px; padding: 0.8rem 1rem; margin-bottom: 1rem; }
.topic-pill .tp-label { font-size: 0.65rem; opacity: 0.6; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
.topic-pill .tp-name { font-family: 'Libre Baskerville', serif; font-size: 0.95rem; }

/* WAVE */
.wave-div { text-align: center; color: var(--gray-mid); font-size: 0.9rem; letter-spacing: 0.4rem; margin: 1.2rem 0; }

/* FOOTER */
.church-footer { text-align: center; padding: 2rem 1rem 1.5rem; color: var(--text-soft); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border-top: 1px solid var(--gray); margin-top: 1rem; }

@media (max-width: 420px) {
  .tab-bar button { font-size: 0.6rem; padding: 0.8rem 0.2rem 0.7rem; }
  main { padding: 1.2rem 0.75rem 3rem; }
  .hero-logo { max-width: 280px; }
  .name-row { grid-template-columns: 1fr; }
  .session-code { font-size: 1.5rem; }
}
</style>
</head>
<body>


<!-- ── Collage fondo ──────────────────────────────────────────────────────── -->
<div id="login-collage" style="display:block">
  
</div>
<!-- ── Login Overlay ─────────────────────────────────────────────────────── -->
<div id="login-overlay">
  <div class="login-box">
